{
  "buildCommand": "npm run build:prod",
  "outputDirectory": "dist/inventory-store-app/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://inventory-store-9g45.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}